[Unit]
Description=DartSystem Service
After=network.target display-manager.service
Wants=display-manager.service

[Service]
Type=simple
User=dartsystem
WorkingDirectory=/opt/dartsystem
Environment=PYTHONUNBUFFERED=1
Environment=QT_QPA_PLATFORM=xcb
Environment=MVCAM_COMMON_RUNENV=/opt/dartsystem/MvImport_Linux
ExecStart=/opt/dartsystem/.venv/bin/python /opt/dartsystem/main.py
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
